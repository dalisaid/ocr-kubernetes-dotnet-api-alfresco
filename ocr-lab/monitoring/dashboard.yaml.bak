          },
          "pluginVersion": "12.3.1",
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "sum(rate(ocr_requests_total{status=\"success\"}[1m])) by (engine)",
              "legendFormat": "{{engine}} - success",
              "refId": "A"
            },
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "sum(rate(ocr_requests_total{status=\"error\"}[1m])) by (engine)",
